# macOS
.DS_Store

# Archivos temporales de scripts
temp_*.xlsx
~$*
*_batch.json
*_batch_result.json

# Settings locales (no compartir)
.claude/settings.local.json

# Mapeo R2 indexado (se regenera consultando el bucket, ~5MB)
new-output_v2/r2_mapeo.json

# Logs
*.log

# Python
__pycache__/
*.pyc

# CSVs intermedios por categoria (se regeneran con scripts/01_extraer_categorias.py
# desde input/INPUT.xlsx). Los enriched/ y corrected/ si se versionan.
/output/*.csv
